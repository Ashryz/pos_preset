<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Extend the ControlButtons template to add Preset button -->
    <t t-name="pos_preset.presetControlButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">

        <xpath expr="//button[@t-on-click='() => this.pos.clickSaveOrder()']" position="before">
            <button class="btn btn-light btn-lg lh-lg flex-shrink-0"
                    t-on-click="() => this.clickPreset()"
                    t-if="!props.showRemainingButtons and !ui.isSmall">
                <span t-if="currentOrder?.preset_id?.name" t-esc="currentOrder.preset_id.name"/>
                <span t-else="">Preset</span>
            </button>
        </xpath>

        <!-- Add Preset button in MODAL VIEW (before pricelist button) -->
        <xpath expr="//button[@class='o_pricelist_button btn btn-secondary btn-lg py-5']" position="before">
            <button class="o_preset_button btn btn-secondary btn-lg py-5" t-on-click="() => this.clickPreset()">
                <i class="fa fa-cutlery me-2" role="img" aria-label="Preset" title="Preset"/>
                <t t-if="currentOrder?.preset_id" t-esc="currentOrder.preset_id.name"/>
                <t t-else="">Preset</t>
            </button>
        </xpath>
    </t>

</templates>
